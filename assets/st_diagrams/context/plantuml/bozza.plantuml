
@startuml C4_Level1_SystemContext
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

LAYOUT_WITH_LEGEND()

title C4 Level 1 — System Context: Code Guardian

Person(developer, "Developer / Tech Lead", "Utente che sottomette repository GitHub e consulta i report di audit e remediation.")

System(codeGuardian, "Code Guardian", "Piattaforma web ad agenti AI per l'audit automatico di repository software: analisi test, sicurezza OWASP e documentazione.")

System_Ext(github, "GitHub", "Hosting dei repository software da analizzare. Fornisce il codice sorgente tramite API REST.")

System_Ext(llmApi, "LLM API (Claude / Bedrock)", "Modello linguistico large usato dagli agenti AI per ragionamento, analisi e generazione di remediation.")

Rel(developer, codeGuardian, "Invia URL repository, consulta report, accetta/rifiuta remediation", "HTTPS / Browser")
Rel(codeGuardian, github, "Scarica codice sorgente e metadati del repository", "HTTPS / GitHub API")
Rel(codeGuardian, llmApi, "Invia contesto di analisi, riceve risultati e suggerimenti", "HTTPS / REST")

@enduml
