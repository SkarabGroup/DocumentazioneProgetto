@startuml Registration
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

title Container Diagram - Registrazione CodeGuardian

Person(user, "Utente non Registrato", "Un cliente che non dispone delle credenziali di un account CodeGuardian")

    Container(web_app, "Web Application", "React/Angular", "Fornisce l'interfaccia per l'inserimento dati e validazione client-side (UC1.1.1, 1.2.1).")
    Container(reg_service, "Registration Service", "Node.js/Spring Boot", "Gestisce la logica di registrazione e coordina la persistenza (UC1).")

System_Ext(aws_db, "AWS Database", "Memorizza i dati utente e gestisce i vincoli di univocità (UC1.1.2, 1.2.2).")
System_Ext(aws_ses, "AWS SES", "Invia l'email di conferma.")

Rel(user, web_app, "Inserisce credenziali", "HTTPS")
Rel(web_app, reg_service, "Invia dati di registrazione", "JSON/HTTPS")
Rel(reg_service, aws_db, "Verifica univocità e salva", "SDK/SQL")
Rel(reg_service, aws_ses, "Invia richiesta email", "SDK")
@enduml